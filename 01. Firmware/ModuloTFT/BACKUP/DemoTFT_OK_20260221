            draw_pixel(x,y,0xFFFF);
}

void test_gradiente(){

    for(int x=0;x<TFT_W;x++){
        uint8_t r = x*31/TFT_W;
        uint16_t c = (r<<11);
        fill_rect(x,0,1,TFT_H,c);
    }
}



// ------- DIGITOS 7 SEG -------

const uint8_t digitos7[10] = {
    0b1111110,
    0b0110000,
    0b1101101,
    0b1111001,
    0b0110011,
    0b1011011,
    0b1011111,
    0b1110000,
    0b1111111,
    0b1111011
};

void seg_h(int x,int y,int w,int h,uint16_t c){
    fill_rect(x,y,w,h,c);
}

void seg_v(int x,int y,int w,int h,uint16_t c){
    fill_rect(x,y,w,h,c);
}

void draw_big_digit(int d,int x,int y,uint16_t c){

    int W=30;
    int H=50;
    int T=8;

    uint8_t s = digitos7[d];

    if(s & 0b1000000) seg_h(x+T,y, W-2*T,T,c);            // A
    if(s & 0b0100000) seg_v(x+W-T,y+T,T,H/2-T,c);         // B
    if(s & 0b0010000) seg_v(x+W-T,y+H/2,T,H/2-T,c);       // C
    if(s & 0b0001000) seg_h(x+T,y+H-T,W-2*T,T,c);         // D
    if(s & 0b0000100) seg_v(x,y+H/2,T,H/2-T,c);           // E
    if(s & 0b0000010) seg_v(x,y+T,T,H/2-T,c);             // F
    if(s & 0b0000001) seg_h(x+T,y+H/2-T/2,W-2*T,T,c);     // G
}

void draw_big_number(int num,uint16_t color){

    int d1 = (num/10)%10;
    int d2 = num%10;

    draw_big_digit(d1,60,50,color);
    draw_big_digit(d2,260,50,color);
}



